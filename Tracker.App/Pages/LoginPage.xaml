<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:Tracker.App.PageModels"             
             xmlns:models="clr-namespace:Tracker.App.Models"
             xmlns:controls="clr-namespace:Tracker.App.Pages.Controls"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Tracker.App.Pages.LoginPage"
             x:DataType="pageModels:LoginPageModel"
             x:Name="LoginPageName"
             Title="Home">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference LoginPageName}, x:DataType=ContentPage}"
                EventName="NavigatedTo"
                Command="{Binding NavigatedToCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference LoginPageName}, x:DataType=ContentPage}"
                EventName="NavigatedFrom"
                Command="{Binding NavigatedFromCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference LoginPageName}, x:DataType=ContentPage}"
                EventName="Appearing"                
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <pullToRefresh:SfPullToRefresh
            IsRefreshing="{Binding IsRefreshing}"
            RefreshCommand="{Binding RefreshCommand}">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <ScrollView>
                    <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">
                        <Label
                            Text="Log in"
                            Style="{StaticResource Headline}"
                            SemanticProperties.HeadingLevel="Level1" />

                        <Label
                            Text="Use a local account to log in, then enable fingerprint, face, or PIN for quick sign-in."
                            Style="{StaticResource SubHeadline}"
                            SemanticProperties.HeadingLevel="Level2" />

                        <BoxView
                            HeightRequest="1"
                            Opacity="0.2" />

                        <Label
                            x:Name="MessageLabel"
                            BackgroundColor="#FDE7E9"
                            Padding="12,8"
                            TextColor="#8A1F17"
                            IsVisible="{Binding IsMessageVisible}"
                            Text="{Binding Message}" />            

                        <Label Text="Email" />
                        <Entry
                            x:Name="EmailEntry"
                            Keyboard="Email"
                            Placeholder="name@example.com"
                            ClearButtonVisibility="WhileEditing"
                            Text="{Binding Email}" />

                        <Label Text="Password" />
                        <Entry
                            x:Name="PasswordEntry"
                            IsPassword="True"
                            Text="{Binding Password}"
                            Placeholder="password"
                            ClearButtonVisibility="WhileEditing" />

                        <HorizontalStackLayout Spacing="10">
                            <CheckBox x:Name="RememberMeCheckBox"
                                      IsChecked="{Binding RememberMe}" />
                            <Label
                                VerticalOptions="Center"
                                Text="Remember me" />       
                        </HorizontalStackLayout>

                        <Button
                            x:Name="LoginButton"
                            Text="Log in"
                            Command="{Binding LoginCommand}"
                            HorizontalOptions="Fill" />     

                        <Button
                            Text="Register"
                            Command="{Binding RegisterCommand}"
                            HorizontalOptions="Fill" />
                        
                    </VerticalStackLayout>
                </ScrollView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>

        <controls:AddButton 
            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
            Command="{Binding AddTaskCommand}"
            ToolTipProperties.Text="Add task"
            SemanticProperties.Description="Add task" />
    </Grid>
</ContentPage>
