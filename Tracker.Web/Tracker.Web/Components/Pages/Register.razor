@page "/register"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Register</PageTitle>

<h1>Register</h1>
<p>Create an account in MauiBlazorWeb.Web.</p>

@if (!string.IsNullOrWhiteSpace(Status))
{
    <p class="text-success">@Status</p>
}

@if (!string.IsNullOrWhiteSpace(Error))
{
    <p class="text-danger">@Error</p>
}

<form method="post" action="/account/register">
    <AntiforgeryToken />
    <input type="hidden" name="ReturnUrl" value="@NormalizedReturnUrl" />

    <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input id="email" name="Email" class="form-control" type="email" autocomplete="username" required />
    </div>

    <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input id="password" name="Password" class="form-control" type="password" autocomplete="new-password" minlength="6" required />
    </div>

    <div class="mb-3">
        <label class="form-label" for="confirm-password">Confirm password</label>
        <input id="confirm-password" name="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" minlength="6" required />
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <a class="btn btn-outline-secondary ms-2" href="@loginUrl">Back to log in</a>
</form>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? Status { get; set; }

    private string NormalizedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;

    private string loginUrl => $"/login?returnUrl={Uri.EscapeDataString(NormalizedReturnUrl)}";
}
